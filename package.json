{
  "name": "blaze",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010 --webpack",
    "setup:api": "cd backend && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "dev:api": "cd backend && .venv/bin/uvicorn app.main:app --reload --port 8000",
    "dev:all": "docker compose up postgres -d && concurrently --kill-others-on-fail -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev\"",
    "start:app": "npm run dev:all",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:vectors": "docker compose exec -T postgres psql -U lefteris -d lefteris_os -f - < prisma/migrations/20250621000000_add_context_vectors/embedding.sql",
    "db:setup": "docker compose up postgres -d && sleep 2 && npm run db:push && npm run db:vectors",
    "db:studio": "prisma studio",
    "mcp": "tsx src/mcp/server.ts",
    "blaze": "cd backend && .venv/bin/python blaze.py",
    "desktop:dev": "cd desktop && npm run tauri:dev",
    "desktop:build": "cd desktop && npm run tauri:build",
    "desktop:install": "cd desktop && npm install"
  },
  "dependencies": {
    "@elevenlabs/client": "^1.12.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "date-fns": "^4.4.0",
    "dotenv": "^16.5.0",
    "googleapis": "^173.0.0",
    "jose": "^6.0.11",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
