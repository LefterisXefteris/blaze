# Blaze local environment — copy to .env and fill in YOUR values.
# Never commit .env. This file is tracked with empty placeholders only.

# Local Postgres + pgvector — Docker service `postgres` in docker-compose.yml
# Use localhost for Next.js/Prisma on your Mac; ./run.sh overrides these for api/worker containers.
DATABASE_URL="postgresql://lefteris:lefteris@localhost:5432/lefteris_os"
DIRECT_URL="postgresql://lefteris:lefteris@localhost:5432/lefteris_os"

# Session JWT for Next.js + FastAPI (any long random string)
BLAZE_JWT_SECRET="change-me-to-a-long-random-string"

# App URL (OAuth redirects) — Blaze uses 3010 by default (3000 is often Grafana)
NEXT_PUBLIC_APP_URL="http://localhost:3010"

# FastAPI backend (Next.js proxies /api/* here)
API_URL="http://127.0.0.1:8000"

# Redis — required when using docker compose worker (./run.sh up)
REDIS_URL="redis://localhost:6379"

# ngrok — started automatically by ./run.sh up (tunnels API :8000 for Slack/webhooks)
# SKIP_NGROK="1"          # set to disable ngrok
# NGROK_PORT="8000"       # port to expose (default: Blaze API)

# Google OAuth (optional — for Sign in with Google + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub App / OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_WEBHOOK_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""

# --- Third-party API keys (bring your own; leave blank to disable that feature) ---

# OpenAI — embeddings, vector search, live notes, intent extraction
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Langfuse — optional LLM observability (open-source, self-hosted only — no Langfuse Cloud)
# 1. Start local stack: docker compose -f docker-compose.langfuse.yml up -d
# 2. Open http://localhost:3100 (login: admin@blaze.local / blaze-langfuse-admin by default)
# 3. Enable tracing in Blaze with the keys below (auto-created by headless init in docker-compose.langfuse.yml)
# LANGFUSE_ENABLED="true"
# LANGFUSE_PUBLIC_KEY="pk-lf-blaze-dev"
# LANGFUSE_SECRET_KEY="sk-lf-blaze-dev"
# LANGFUSE_HOST="http://localhost:3100"
# LANGFUSE_LIVE_NOTES_SAMPLE_RATE="0.2"

# ElevenLabs Scribe — realtime voice transcription for Slack huddles
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=""

# Local coding-agent handoff files (default: mapped repo /.blaze/handoffs, else nearest git repo)
# BLAZE_HANDOFF_DIR="/Users/you/projects/my-repo/.blaze/handoffs"

# Map GitHub repos to local checkouts (handoffs + Cursor open the mapped workspace)
# BLAZE_REPO_MAP="ClickHouse/ClickHouse=/Users/you/projects/ClickHouse,LefterisXefteris/DataTable=/Users/you/projects/DataTable"
# Or edit ~/.blaze/repos.json — also configurable in Connections → Local repos

# Cursor integration on handoff write (auto | add | open | off)
BLAZE_CURSOR_HANDOFF="auto"
# Drop .cursor/rules/blaze-handoff.mdc pointing at the active handoff (true | false)
BLAZE_CURSOR_RULES="true"

# CLI: npm run blaze -- handoff <action-id> --run
# BLAZE_USER_ID="your-blaze-user-uuid"

# Desktop app — use BLAZE_CURSOR_HANDOFF=off on cloud API; desktop delivers locally
# BLAZE_DESKTOP_HANDOFF_ONLY="true"

# Local UI preview without Google OAuth
DEV_DEMO_LOGIN="true"
