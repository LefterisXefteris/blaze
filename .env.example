# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Prisma connects to Supabase Postgres (Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# App URL (OAuth redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# FastAPI backend (Next.js proxies /api/* here)
API_URL="http://127.0.0.1:8000"

# Redis (optional — omit unless running Redis; app uses in-process queue by default)
# docker compose up redis
# REDIS_URL="redis://localhost:6379"

# Google OAuth — configure in Supabase Dashboard → Auth → Providers → Google
# Also used for Calendar API token refresh
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub App / OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_WEBHOOK_SECRET=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""

# OpenAI (required for vector embeddings + live notes context)
OPENAI_API_KEY=""

# Local coding-agent handoff files (default: nearest git repo /.blaze/handoffs)
# BLAZE_HANDOFF_DIR="/Users/you/projects/my-repo/.blaze/handoffs"

# Cursor integration on handoff write (auto | add | open | off)
BLAZE_CURSOR_HANDOFF="auto"
# Drop .cursor/rules/blaze-handoff.mdc pointing at the active handoff (true | false)
BLAZE_CURSOR_RULES="true"

# CLI: npm run blaze -- handoff <action-id> --run
# BLAZE_USER_ID="your-blaze-user-uuid"

# Desktop app — use BLAZE_CURSOR_HANDOFF=off on cloud API; desktop delivers locally
# BLAZE_DESKTOP_HANDOFF_ONLY="true"

# Supabase JWT secret (Settings → API → JWT Secret) — used by FastAPI auth
SUPABASE_JWT_SECRET=""

# Local UI preview without Supabase Google OAuth
DEV_DEMO_LOGIN="true"
